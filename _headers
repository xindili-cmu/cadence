# Security response headers for all routes.
# Cloudflare Workers static assets reads this file automatically; it is not
# served as a public asset. Syntax: a path pattern line, then indented headers.

/*
  # Force HTTPS for 1 year incl. subdomains. (No `preload` — that's an
  # irreversible browser-list commitment; add it later if you're sure.)
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  # Block this site from being framed (clickjacking). frame-ancestors is the
  # modern form; X-Frame-Options covers older browsers.
  X-Frame-Options: DENY
  # Stop browsers from MIME-sniffing responses into a different type.
  X-Content-Type-Options: nosniff
  # Don't leak full URLs to third parties in the Referer header.
  Referrer-Policy: strict-origin-when-cross-origin
  # Deny powerful APIs the site never uses.
  Permissions-Policy: camera=(), microphone=(), geolocation=(), browsing-topics=()
  # Content Security Policy.
  #   'unsafe-inline' is required because index.html has inline <script>/<style>
  #     blocks and an inline onerror= handler (nonces can't cover handlers).
  #   'unsafe-eval' + https://unpkg.com are ONLY needed by the Babel fallback
  #     boot that runs if app.min.js is missing; production never hits it but we
  #     keep it working. Remove both if you ever drop that fallback.
  #   cdn.jsdelivr.net = LXGW Wenkai web font (imported in fonts.css → loads
  #     its own CSS + woff2). formspree.io = the feedback/suggest forms POST
  #     there via fetch (connect-src).
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://unpkg.com; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; img-src 'self' data:; font-src 'self' https://cdn.jsdelivr.net; connect-src 'self' https://formspree.io; base-uri 'self'; form-action 'self' https://formspree.io; frame-ancestors 'none'; object-src 'none'
